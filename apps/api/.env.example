APP_ENV=development
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

DATABASE_URL=postgresql+asyncpg://knesset:knesset@localhost:5432/knessetil
DATABASE_POOL_SIZE=10

OKNESSET_BASE_URL=https://production.oknesset.org/pipelines/data
OKNESSET_SYNC_INTERVAL_HOURS=6

RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_SEARCH=30/minute

# AI explanations (Claude). Leave ANTHROPIC_API_KEY blank to disable the feature
# (the endpoint returns 503 and the frontend hides the button).
ANTHROPIC_API_KEY=
AI_EXPLANATION_MODEL=claude-haiku-4-5
AI_EXPLANATIONS_ENABLED=true

LOG_LEVEL=INFO
