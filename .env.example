# ── Root .env.example ─────────────────────────────────────────────────────────
# Copy relevant sections to apps/api/.env and apps/web/.env.local

# ─── API (apps/api/.env) ──────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

DATABASE_URL=postgresql+asyncpg://knesset:knesset@localhost:5432/knessetil
DATABASE_POOL_SIZE=10

OKNESSET_BASE_URL=https://production.oknesset.org/pipelines/data
OKNESSET_SYNC_INTERVAL_HOURS=6

RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_SEARCH=30/minute

LOG_LEVEL=INFO

# ─── Web (apps/web/.env.local) ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ─── Docker / Infra ───────────────────────────────────────────────────────────
POSTGRES_USER=knesset
POSTGRES_PASSWORD=knesset
POSTGRES_DB=knessetil
