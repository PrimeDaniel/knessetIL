# ===========================================================================
# KnessetIL — Root Environment Example
# Copy relevant sections to apps/web/.env.local and apps/api/.env
# ===========================================================================

# ── Frontend (apps/web/.env.local) ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ── Backend (apps/api/.env) ──────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://knesset:knesset@localhost:5432/knessetil
DATABASE_POOL_SIZE=10

# Open Knesset data source
OKNESSET_BASE_URL=https://production.oknesset.org/pipelines/data
OKNESSET_SYNC_INTERVAL_HOURS=6

# Rate limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_SEARCH=30/minute

# Logging
LOG_LEVEL=INFO

# ── Docker / Infra (.env at infra/) ─────────────────────────────────────────
POSTGRES_USER=knesset
POSTGRES_PASSWORD=knesset
POSTGRES_DB=knessetil
