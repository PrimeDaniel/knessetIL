# ── Root .env.example ─────────────────────────────────────────────────────────
# Copy the relevant sections to:
#   apps/api/.env          (FastAPI backend)
#   apps/web/.env.local    (Next.js frontend, local dev)
#
# In production:
#   - API env vars are set in your API host's dashboard (Render / Fly / Railway).
#   - Web env vars are set in the Netlify site dashboard.
# Never commit a real .env. This file holds NO secret values.

# ─── API (apps/api/.env) ──────────────────────────────────────────────────────

# "development" or "production". When "production", /docs and /redoc are hidden.
APP_ENV=development
APP_PORT=8000

# Comma-separated origins allowed by CORS.
# Local dev: http://localhost:3000
# Production: https://<your-netlify-site>.netlify.app  (and your custom domain, if any)
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (Windows): the Postgres instance set up per CLAUDE.md.
#   postgresql+asyncpg://knesset:knesset@localhost:5432/knessetil
#
# Supabase production: use the "Session pooler" string (port 5432) from the
# Supabase dashboard — NOT the Transaction pooler (6543). This app holds a
# persistent SQLAlchemy/asyncpg connection pool, and asyncpg's prepared
# statements break under pgBouncer transaction mode. Session mode works.
# Then swap the driver prefix to "postgresql+asyncpg://" and append "?ssl=require".
# URL-encode any special characters in the password (@ -> %40, etc.).
# Example shape (do NOT paste a real password here):
#   postgresql+asyncpg://postgres.<project-ref>:<PASSWORD>@<region>.pooler.supabase.com:5432/postgres?ssl=require
DATABASE_URL=postgresql+asyncpg://knesset:knesset@localhost:5432/knessetil
DATABASE_POOL_SIZE=10

# ── Open Knesset CSV sync ─────────────────────────────────────────────────────
OKNESSET_BASE_URL=https://production.oknesset.org/pipelines/data
OKNESSET_SYNC_INTERVAL_HOURS=6

# Restrict sync to a single Knesset number to keep the Supabase database small
# enough for the free tier. Recommended in production: 25 (current Knesset).
# Leave UNSET / blank in local dev to sync everything.
# OKNESSET_KNESSET_FILTER=25

# Run the 6h sync inside the API process. Local dev: true (self-contained).
# Production: set to false — a GitHub Actions cron (.github/workflows/sync.yml)
# owns the sync, so the API host can scale to zero without missing a run.
ENABLE_SYNC_SCHEDULER=true

# ── Rate limiting & logging ───────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_SEARCH=30/minute
LOG_LEVEL=INFO

# ─── Web (apps/web/.env.local) ────────────────────────────────────────────────
# Local dev: point at the local FastAPI on :8000.
# Production (Netlify): set NEXT_PUBLIC_API_URL in the Netlify site dashboard to
# your deployed API URL, e.g. https://knessetil-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENABLE_ANALYTICS=false
